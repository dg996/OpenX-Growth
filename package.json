{
  "name": "openx-growth",
  "version": "0.1.0",
  "description": "Self-hosted, open-source X growth intelligence, content and scheduling tools.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/dg996/OpenX-Growth.git"
  },
  "bugs": {
    "url": "https://github.com/dg996/OpenX-Growth/issues"
  },
  "homepage": "https://github.com/dg996/OpenX-Growth#readme",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "install:ci": "bash scripts/install-ci.sh",
    "setup": "node scripts/cli/init.mjs",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vite",
    "build": "bash scripts/build-verified.sh",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && npm run test:unit && npm run test:metadata",
    "test:unit": "node --experimental-strip-types --test tests/*.test.ts",
    "test:metadata": "node --test tests/rendered-html.test.mjs",
    "test:e2e:demo": "node --test tests/e2e-smoke.test.mjs",
    "test:e2e:misconfigured": "node --test tests/e2e-misconfigured.test.mjs",
    "test:e2e:configured": "node --test tests/e2e-configured.test.mjs",
    "test:e2e": "node scripts/run-e2e.mjs",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm test",
    "privacy:audit": "node scripts/privacy-audit.mjs",
    "release:check": "npm run privacy:audit && npm run check && npm run test:e2e",
    "mcp": "node mcp/server.mjs",
    "deploy:cloudflare": "wrangler deploy --config wrangler.jsonc",
    "db:migrate:local": "wrangler d1 migrations apply DB --local --config wrangler.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote --config wrangler.jsonc",
    "validate:artifact": "bash scripts/validate-artifact.sh",
    "lint": "bash scripts/sites-env.sh -- eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "bash scripts/sites-env.sh -- drizzle-kit generate"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^0.468.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "19.2.7",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    }
  },
  "type": "module",
  "displayName": "OpenX Growth"
}
