# Public deployment origin; no trailing slash.
APP_URL=http://localhost:3000

# X OAuth 2.0 application. X_CLIENT_SECRET is optional for public PKCE clients.
X_CLIENT_ID=
X_CLIENT_SECRET=

# Generate independent random values. Never commit real values.
SESSION_SECRET=
APP_ACCESS_TOKEN=
CRON_SECRET=
OPENX_API_TOKEN=

# Optional OpenAI-compatible provider. AI remains blocked unless X approval flags are true.
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-5-mini
X_AI_CONTENT_APPROVED=false
X_AI_REPLIES_APPROVED=false

# Repeated publishing can violate automation/spam rules if misused. Keep disabled unless your use case permits it.
ENABLE_EVERGREEN=false

# Cost controls.
SYNC_TTL_SECONDS=900
MAX_DAILY_X_READS=500
MAX_DAILY_X_WRITES=50

# MCP process only; usually set outside the web deployment.
OPENX_BASE_URL=http://localhost:3000
