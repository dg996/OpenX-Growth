# Required. Public deployment origin with no trailing slash.
# `npm run setup` detects or asks for this value and writes it automatically.
APP_URL=http://localhost:3000

# Bootstrap fallback for X. After first sign-in, manage X credentials in Settings → X account.
X_CLIENT_ID=
# Required only when X created a confidential Web App client. Public PKCE clients leave it empty.
X_CLIENT_SECRET=

# Generated independently by `npm run setup`. Never commit or share real values.
# SESSION_SECRET encrypts OAuth tokens stored in D1.
SESSION_SECRET=
# APP_ACCESS_TOKEN protects browser access. The wizard creates the initial value; replace it later in Settings → Security.
APP_ACCESS_TOKEN=
# CRON_SECRET protects scheduled publishing. It is also replaceable in Settings → Publishing.
CRON_SECRET=
# OPENX_API_TOKEN protects REST/MCP access and the setup healthcheck. It is also replaceable in Settings → Publishing.
OPENX_API_TOKEN=

# Optional fallback defaults. Prefer Settings → AI provider; saved values are encrypted in D1.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-5-mini
# Keep both policy gates false unless the operator has confirmed the approved X use case permits them.
X_AI_CONTENT_APPROVED=false
X_AI_REPLIES_APPROVED=false

# Editable in Settings → Publishing. Keep disabled unless your use case permits it.
ENABLE_EVERGREEN=false

# Optional fallback defaults. Manage cache in Settings → Publishing and caps in Settings → Limits.
SYNC_TTL_SECONDS=900
MAX_DAILY_X_RESOURCES=500
MAX_DAILY_X_WRITES=50
# Legacy fallback accepted for existing deployments when MAX_DAILY_X_RESOURCES is unset:
# MAX_DAILY_X_READS=500

# MCP process only. Pass it to `npm run mcp`; the Worker does not read it.
OPENX_BASE_URL=http://localhost:3000
